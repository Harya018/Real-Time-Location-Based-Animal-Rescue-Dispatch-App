# Server Configuration
PORT=3000

# Database Configuration (SQLite path is usually relative)
# For production systems, you might use different values here if swapping to Postgres/MariaDB
DB_USER=your_db_user_here
DB_HOST=localhost
DB_NAME=rescue_platform
DB_PASSWORD=your_db_password_here
DB_PORT=5432

# AI Services API Keys (REQUIRED for full functionality)
# Get your Gemini key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Get your OpenAI key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Maps (Optional context for some features)
MAPBOX_TOKEN=your_mapbox_token_here
